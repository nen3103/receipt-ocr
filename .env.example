# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Cloud Vision (サービスアカウントJSONのパス)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# デフォルト設定（任意）
DEFAULT_OCR_ENGINE=cloud_vision   # cloud_vision | tesseract
DEFAULT_AI_MODEL=openai_gpt4o     # openai_gpt4o | anthropic_claude
