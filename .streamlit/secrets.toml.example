# Streamlit Community Cloud の「Secrets」画面にこの内容を貼り付けてください
# ローカルで使う場合は secrets.toml にリネームして使用（.gitignore 対象）

APP_PASSWORD = "your_shared_password_here"

OPENAI_API_KEY = "sk-..."
ANTHROPIC_API_KEY = "sk-ant-..."

# Google Cloud Vision を使う場合は JSON の中身を丸ごと貼る
# [gcp_service_account]
# type = "service_account"
# project_id = "..."
# private_key_id = "..."
# private_key = "-----BEGIN RSA PRIVATE KEY-----\n..."
# client_email = "..."
# client_id = "..."
